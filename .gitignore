# Ignore everything by default
/*

# ── Allow-list: Essential Source Code ─────────────────────────────────────────

!/src/
!/main.py
!/config.py
!/.gitignore
!/README.md
!/requirements.txt
!/.env.example
!/dataset/

# ── Explicitly Ignore: Sensitive and Large Data ───────────────────────────────

# Results (TXT, JSON, JSONL logs)
/results/

# Environment Variables
.env

# Python Bytecode and Cache
**/__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
.pytest_cache/
.coverage
htmlcov/
.DS_Store
